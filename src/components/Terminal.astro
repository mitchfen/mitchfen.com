---
import "../styles/app.css";
---

<div class="terminal-container" id="terminalContainer">
    <div class="terminal-output">
        <div id="outputLines"></div>

        <div class="input-row" id="inputRow" style="display: none;">
            <span class="prompt">><span class="prompt-char"></span></span>
            <div class="input-wrapper">
                <input
                    id="terminalInput"
                    class="terminal-input"
                    spellcheck="false"
                    autocomplete="off"
                    type="text"
                />
                <span class="terminal-cursor-spacer" id="cursorSpacer"
                ></span><span class="terminal-cursor"></span>
            </div>
        </div>
    </div>
</div>

<script>
    const terminalContainer = document.getElementById(
        "terminalContainer",
    ) as HTMLDivElement;
    const outputLines = document.getElementById(
        "outputLines",
    ) as HTMLDivElement;
    const terminalInput = document.getElementById(
        "terminalInput",
    ) as HTMLInputElement;
    const cursorSpacer = document.getElementById(
        "cursorSpacer",
    ) as HTMLSpanElement;

    // Helper to escape HTML characters
    function escapeHtml(str: string): string {
        return str
            .replace(/&/g, "&amp;")
            .replace(/</g, "&lt;")
            .replace(/>/g, "&gt;")
            .replace(/"/g, "&quot;")
            .replace(/'/g, "&#039;");
    }

    // Keep scroll at the bottom
    function scrollToBottom() {
        if (terminalContainer) {
            terminalContainer.scrollTop = terminalContainer.scrollHeight;
        }
    }

    // Helper to add HTML content lines
    function addLine(htmlContent: string, className = "terminal-line") {
        if (!outputLines) return;
        const line = document.createElement("div");
        line.className = className;
        line.innerHTML = htmlContent;
        outputLines.appendChild(line);
    }

    // Process commands
    function processCommand(rawCmd: string) {
        const cmd = rawCmd.trim().toLowerCase();

        if (cmd.startsWith("sudo ") || cmd === "sudo") {
            addLine(
                "<span class='red'>User is not in the sudoers file. This incident will be reported.</span>",
            );
            return;
        }

        if (cmd.startsWith("cd ") || cmd === "cd") {
            const targetDir = rawCmd.trim().slice(2).trim() || "~";
            addLine(
                `<span class='red'>cd: ${escapeHtml(targetDir)}: Permission denied</span>`,
            );
            return;
        }

        if (cmd.startsWith("ls ") || cmd === "ls") {
            addLine("");
            return;
        }

        switch (cmd) {
            case "about":
                addLine("This is <span class='cyan'>Mitchell Fenner</span>'s personal website.");
                addLine(
                    "I'm a Senior Cloud Operations engineer focused on Azure, Kubernetes, SaaS, DevOps, and automating everything.",
                );
                addLine(
                    "Outside my day job, I enjoy hacking on my personal cloud (aka " +
                        "<a href='https://github.com/mitchfen/homelab' target='_blank' rel='noopener noreferrer'>" +
                        "my homelab</a>), and rock climbing.",
                );
                break;

            case "links":
                addLine(
                    "Email: <a href='mailto:mitch@mitchfen.com' target='_blank' rel='noopener noreferrer'>mitch@mitchfen.com</a>",
                );
                addLine(
                    "LinkedIn: <a href='https://linkedin.com/in/mitchfen' target='_blank' rel='noopener noreferrer'>linkedin.com/in/mitchfen</a>",
                );
                addLine(
                    "GitHub: <a href='https://github.com/mitchfen' target='_blank' rel='noopener noreferrer'>github.com/mitchfen</a>",
                );
                addLine(
                    "Substack: <a href='https://substack.com/@mitchfen' target='_blank' rel='noopener noreferrer'>substack.com/@mitchfen</a>",
                );
                break;

            case "clear":
                if (outputLines) {
                    outputLines.innerHTML = "";
                }
                break;

            case "pwd":
                addLine("/home/guest");
                break;

            case "help":
                addLine(
                    "Available commands: [about, links, sudo, ls, cd, pwd, clear]",
                );
                break;

            default:
                const encoded = escapeHtml(rawCmd);
                addLine(
                    `<span class='red'>Command not found: ${encoded}</span>`,
                );
                addLine("");
                processCommand("help");
                break;
        }
    }

    // Execute entered command
    function executeCommand() {
        if (!terminalInput || !cursorSpacer) return;
        const cmd = terminalInput.value;
        const trimmed = cmd.trim().toLowerCase();

        // Render command prompt line
        const encoded = escapeHtml(cmd);
        const cmdRowHtml = `<span class="prompt">><span class="prompt-char"></span></span><span class="cmd-text gray">${encoded}</span>`;
        addLine(cmdRowHtml, "executed-cmd");

        if (trimmed.length > 0) {
            processCommand(trimmed);
        } else {
            addLine("", "terminal-line");
        }

        terminalInput.value = "";
        cursorSpacer.textContent = "";
        scrollToBottom();
    }

    // Auto-typing animation helper
    async function typeCommand(cmd: string) {
        if (!terminalInput || !cursorSpacer) return;
        for (const char of cmd) {
            terminalInput.value += char;
            cursorSpacer.textContent = terminalInput.value;
            scrollToBottom();
            await new Promise((resolve) => setTimeout(resolve, 100));
        }
        await new Promise((resolve) => setTimeout(resolve, 300));
        executeCommand();
    }

    // Set up events on DOM load
    if (terminalContainer && terminalInput && cursorSpacer) {
        // Focus input on click anywhere on terminal
        terminalContainer.addEventListener("click", () => {
            terminalInput.focus();
        });

        // Mirror input value to the cursor spacer for positioning
        terminalInput.addEventListener("input", () => {
            cursorSpacer.textContent = terminalInput.value;
            scrollToBottom();
        });

        // Handle Enter keypress
        terminalInput.addEventListener("keydown", (e) => {
            if (e.key === "Enter") {
                executeCommand();
            }
        });

        // Auto-type on startup
        (async () => {
            await new Promise((resolve) => setTimeout(resolve, 100));

            const bootLogs = [
                `<img src='/parrot.gif' alt='party parrot' style='height: 1.5em; display: inline; margin: 0 4px; vertical-align: baseline;' /> Welcome [<span class="yellow">guest</span>] to mitchfen.com <img src='/parrot.gif' alt='party parrot' style='height: 1.5em; display: inline; margin: 0 4px; vertical-align: baseline;' />`
            ];

            for (const log of bootLogs) {
                addLine(log);
                scrollToBottom();
                await new Promise((resolve) => setTimeout(resolve, 20));
            }

            addLine("");

            const inputRow = document.getElementById("inputRow");
            if (inputRow) inputRow.style.display = "flex";

            await new Promise((resolve) => setTimeout(resolve, 600));
            await typeCommand("about");
            await new Promise((resolve) => setTimeout(resolve, 1000));
            await typeCommand("links");
            terminalInput.focus();
        })();
    }
</script>
